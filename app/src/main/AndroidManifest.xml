<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NoteTaking"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".ProfileActivity"
            android:exported="false"
            android:label="@string/title_activity_profile"
            android:theme="@style/Theme.NoteTaking" />
        <activity
            android:name=".DeletedNotesActivity"
            android:exported="false"
            android:label="@string/title_activity_deleted_notes"
            android:theme="@style/Theme.NoteTaking" />
        <activity
            android:name=".NoteComponentsActivity"
            android:exported="false"
            android:label="@string/title_activity_note_components"
            android:theme="@style/Theme.NoteTaking" />
        <activity
            android:name=".BottomNavActivity"
            android:exported="false"
            android:label="@string/title_activity_bottom_nav"
            android:theme="@style/Theme.NoteTaking" />
        <activity
            android:name=".ArchivedActivity"
            android:exported="false"
            android:label="@string/title_activity_archived"
            android:theme="@style/Theme.NoteTaking" />
        <activity
            android:name=".FavoritesActivity"
            android:exported="false"
            android:label="@string/title_activity_favorites"
            android:theme="@style/Theme.NoteTaking" />
        <activity
            android:name=".PinnedActivity"
            android:exported="false"
            android:label="@string/title_activity_pinned"
            android:theme="@style/Theme.NoteTaking" />
        <activity
            android:name=".AllNotesActivity"
            android:exported="false"
            android:label="@string/title_activity_all_notes"
            android:theme="@style/Theme.NoteTaking" />
        <activity
            android:name=".HomeActivity"
            android:exported="false"
            android:label="@string/title_activity_home"
            android:theme="@style/Theme.NoteTaking" /> <!-- SplashActivity - This is the correct Launcher -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:label="@string/title_activity_splash"
            android:theme="@style/Theme.NoteTaking">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity> <!-- Other Activities -->
        <activity
            android:name=".LoginActivity"
            android:exported="false"
            android:label="@string/title_activity_login"
            android:theme="@style/Theme.NoteTaking" />
        <activity
            android:name=".RegisterActivity"
            android:exported="false"
            android:label="@string/title_activity_register"
            android:theme="@style/Theme.NoteTaking" />
        <activity
            android:name=".ForgetPasswordActivity"
            android:exported="false"
            android:label="@string/title_activity_forget_password"
            android:theme="@style/Theme.NoteTaking" />
        <activity
            android:name=".DashboardActivity"
            android:exported="false"
            android:label="@string/title_activity_dashboard"
            android:theme="@style/Theme.NoteTaking" />
    </application>

</manifest>